---
const { pathname } = Astro.url;

const links = [
	{ href: '/work', label: 'Work' },
	{ href: '/build', label: 'Build' },
	{ href: '/travel', label: 'Travel' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/about', label: 'About' },
];

function isActive(href: string) {
	return pathname === href || pathname.startsWith(href + '/');
}
---

<nav class="site-nav">
	<a href="/" class="nav-logo">
		<span id="logo-text">GW</span>
	</a>
	<ul class="nav-links">
		{
			links.map(({ href, label }) => (
				<li>
					<a href={href} class:list={['nav-link', { active: isActive(href) }]}>
						{label}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.site-nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		height: var(--nav-h);
		background: #0f0f0f;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 2rem;
	}

	.nav-logo {
		font-family: var(--font-display);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		color: rgb(var(--black));
		text-decoration: none;
		text-transform: uppercase;
		transition: color 0.2s ease;
		display: inline-block;
	}

	#logo-text {
		min-width: 8.5em;
		display: inline-block;
	}

	.nav-links {
		display: flex;
		list-style: none;
		margin: 0;
		padding: 0;
		gap: 0;
	}

	.nav-link {
		display: block;
		padding: 0.5rem 0.75rem;
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		transition: color 0.2s ease;
	}

	.nav-link:hover {
		color: rgb(var(--black));
	}

	.nav-link.active {
		color: rgb(var(--black));
	}

	@media (max-width: 480px) {
		.site-nav {
			padding: 0 1rem;
		}

		.nav-link {
			padding: 0.5rem 0.5rem;
			font-size: 0.7rem;
		}
	}
</style>

<script>
	const logoText = document.getElementById('logo-text');
	const fullName = 'Gert-Willem';
	const shortName = 'GW';
	let currentTimeout: ReturnType<typeof setTimeout> | null = null;
	let currentText = 'GW';

	const randomDelay = (base, variance) => base + (Math.random() * variance * 2) - variance;
	const logo = document.querySelector('.nav-logo');

	function typeCharacters() {
		if (currentText.length >= fullName.length) return;

		currentText = fullName.substring(0, currentText.length + 1);
		logoText!.textContent = currentText;

		currentTimeout = setTimeout(typeCharacters, randomDelay(100, 60));
	}

	function deleteCharacters() {
		if (currentText.length <= shortName.length) {
			currentText = shortName;
			logoText!.textContent = currentText;
			currentTimeout = null;
			return;
		}

		currentText = currentText.slice(0, -1);
		logoText!.textContent = currentText;

		currentTimeout = setTimeout(deleteCharacters, randomDelay(80, 30));
	}

	logo?.addEventListener('mouseenter', () => {
		if (currentTimeout) clearTimeout(currentTimeout);
		if (currentText === fullName) return;

		typeCharacters();
	});

	logo?.addEventListener('mouseleave', () => {
		if (currentTimeout) clearTimeout(currentTimeout);
		if (currentText === shortName) return;

		deleteCharacters();
	});
</script>
