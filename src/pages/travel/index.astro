---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('travel')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Travel" description="Moto trips and travel.">
	<main class="travel-index">
		<ul>
			{
				posts.map((post) => (
					<li>
						<a href={`/travel/${post.id}/`}>
							<div class="post-image">
								{post.data.heroImage && (
									<Image
										src={post.data.heroImage}
										alt={post.data.title}
										width={480}
										height={320}
									/>
								)}
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<div class="post-meta">
								<span>{post.data.country}</span>
								{!!post.data.distance && <span>{post.data.distance} km</span>}
								<FormattedDate date={post.data.pubDate} />
							</div>
						</a>
					</li>
				))
			}
		</ul>
	</main>
</BaseLayout>

<style>
	.travel-index {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: calc(var(--nav-h) + 3em) 1em 3em;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 2rem;
	}

	li a {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.post-image {
		aspect-ratio: 3 / 2;
		overflow: hidden;
		border-radius: 4px;
		background: rgb(var(--gray-light));
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
		transition: transform 0.35s ease;
	}

	li a:hover .post-image img {
		transform: scale(1.03);
	}

	.post-title {
		margin: 0.75rem 0 0.25rem;
		font-size: 1.15rem;
		font-weight: 600;
		color: rgb(var(--black));
	}

	.post-meta {
		display: flex;
		gap: 1rem;
		color: rgb(var(--gray));
		font-size: 0.8rem;
		font-weight: 300;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
</style>
