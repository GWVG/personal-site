---
import { getImage } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('travel')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts[0] ?? null;

const featuredBgSrc =
	featured?.data.heroImage
		? (await getImage({ src: featured.data.heroImage, width: 1920, format: 'webp', quality: 85 }))
				.src
		: null;
---

<BaseLayout title="Gert-Willem van Gompel" description="Engineer. Builder. Rider.">
	<!-- ─── Hero ─── -->
	<section class="home-hero">
		<div class="name-container">
			<div id="tooltip" class="accept-tooltip">
				<span class="accept-text">Accept</span>
				<span class="tab-badge">Tab</span>
			</div>
			<h1 class="home-name">
				<span id="name-typed"></span><span id="name-cursor" class="cursor"></span><span id="name-suggest" class="autocomplete"></span>
			</h1>
		</div>
		<p class="home-tagline" id="tagline">Engineer.&ensp;Builder.&ensp;Rider.</p>
	</section>

	<!-- ─── Featured travel ─── -->
	{
		featured && (
			<section class="featured-section">
				<a href={`/travel/${featured.id}/`} class="featured-card">
					{featuredBgSrc && (
						<div
							class="featured-bg"
							style={`background-image: url('${featuredBgSrc}')`}
						/>
					)}
					<div class="featured-overlay">
						<p class="featured-label">Latest trip</p>
						<h2 class="featured-title">{featured.data.heroTitle ?? featured.data.title}</h2>
						<p class="featured-meta">
							{featured.data.country}
							{!!featured.data.distance && <> &middot; {featured.data.distance} km</>}
						</p>
					</div>
				</a>
			</section>
		)
	}

	<!-- ─── Section grid ─── -->
	<section class="section-grid">
		<a href="/work" class="section-card">
			<span class="section-label">Work</span>
			<span class="section-desc">Architecture & engineering</span>
		</a>
		<a href="/build" class="section-card">
			<span class="section-label">Build</span>
			<span class="section-desc">ML, agents, systems</span>
		</a>
		<a href="/travel" class="section-card">
			<span class="section-label">Travel</span>
			<span class="section-desc">Moto trips & photography</span>
		</a>
		<a href="/blog" class="section-card">
			<span class="section-label">Blog</span>
			<span class="section-desc">Notes & write-ups</span>
		</a>
	</section>
</BaseLayout>

<style>
	/* ─── Hero ─── */
	.home-hero {
		height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 0 2rem;
	}

	.home-name {
		font-family: var(--font-display);
		font-size: clamp(3rem, 8vw, 7rem);
		font-weight: 700;
		color: rgb(var(--black));
		margin: 0;
		line-height: 1;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.home-tagline {
		margin: 1.5rem 0 0;
		font-size: clamp(0.7rem, 1.5vw, 0.85rem);
		font-weight: 300;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		opacity: 1;
		transition: opacity 0.6s ease;
	}

	.home-tagline.fade-in {
		animation: fadeInWord 1.2s ease forwards;
	}

	@keyframes fadeInWord {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	/* ─── Typewriter cursor ─── */
	.cursor {
		display: inline-block;
		width: 2px;
		height: 0.75em;
		background: currentColor;
		vertical-align: 0.05em;
		animation: blink 0.7s step-start infinite;
		margin-left: 2px;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	/* ─── Autocomplete suggestion ─── */
	.autocomplete {
		color: #666;
		font-weight: 400;
		font-style: italic;
	}

	.autocomplete.accepted {
		color: rgb(var(--black));
		font-style: normal;
	}

	/* ─── Name container with tooltip ─── */
	.name-container {
		position: relative;
		display: inline-block;
	}

	.accept-tooltip {
		position: absolute;
		top: -3.5rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.3rem 0.6rem;
		background: #1e1e1e;
		border: 1px solid #444;
		border-radius: 4px;
		font-size: 0.75rem;
		font-weight: 400;
		color: #aaa;
		white-space: nowrap;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.2s ease;
		z-index: 10;
	}

	.accept-tooltip.visible {
		opacity: 1;
	}

	.tab-badge {
		display: inline-block;
		padding: 0.15rem 0.4rem;
		background: #2d2d2d;
		border: 1px solid #555;
		border-radius: 2px;
		font-family: ui-monospace, monospace;
		font-size: 0.65rem;
		color: #999;
	}

	/* ─── Featured travel ─── */
	.featured-section {
		padding: 0 2rem 1px;
		max-width: 1200px;
		margin: 0 auto;
	}

	.featured-card {
		display: block;
		position: relative;
		height: 60vh;
		min-height: 380px;
		overflow: hidden;
		text-decoration: none;
		background: rgb(var(--gray-light));
	}

	.featured-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		transition: transform 0.7s cubic-bezier(0.25, 0, 0.25, 1);
	}

	.featured-card:hover .featured-bg {
		transform: scale(1.03);
	}

	.featured-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.12) 55%, transparent 100%);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 3rem;
	}

	.featured-label {
		font-size: 0.68rem;
		font-weight: 300;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.45);
		margin: 0 0 0.6rem;
	}

	.featured-title {
		font-family: var(--font-display);
		font-size: clamp(2rem, 4vw, 4rem);
		font-weight: 700;
		color: #fff;
		margin: 0 0 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		line-height: 1.05;
	}

	.featured-meta {
		font-size: 0.8rem;
		font-weight: 300;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.5);
		margin: 0;
	}

	/* ─── Section grid ─── */
	.section-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1px;
		background: rgb(var(--gray-light));
		border-top: 1px solid rgb(var(--gray-light));
		max-width: 1200px;
		margin: 0 auto;
	}

	.section-card {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 2.5rem 2rem;
		background: #0f0f0f;
		text-decoration: none;
		min-height: 180px;
		transition: background 0.2s ease;
	}

	.section-card:hover {
		background: #111;
	}

	.section-label {
		display: block;
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 700;
		color: rgb(var(--black));
		text-transform: uppercase;
		letter-spacing: 0.05em;
		line-height: 1;
		margin-bottom: 0.55rem;
		transition: color 0.2s ease;
	}

	.section-card:hover .section-label {
		color: var(--accent);
	}

	.section-desc {
		display: block;
		font-size: 0.78rem;
		font-weight: 300;
		color: rgb(var(--gray));
		letter-spacing: 0.02em;
	}

	@media (max-width: 768px) {
		.section-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.featured-overlay {
			padding: 2rem;
		}
	}

	@media (max-width: 480px) {
		.featured-section {
			padding: 0 0 1px;
		}

		.featured-card {
			min-height: 300px;
		}

		.section-card {
			padding: 1.75rem 1.25rem;
			min-height: 140px;
		}
	}
</style>

<script>
import { validateEnvVariable } from "astro/env/runtime";

	function initTypewriter() {
		const typedEl = document.getElementById('name-typed');
		const cursorEl = document.getElementById('name-cursor');
		const suggestEl = document.getElementById('name-suggest');
		const taglineEl = document.getElementById('tagline');
		const tooltipEl = document.getElementById('tooltip');

		if (!typedEl || !cursorEl || !suggestEl || !taglineEl || !tooltipEl) return;

		const typed = 'Gert-W';
		const suggestion = 'illem Van Gompel';
		const deleteText = ' VAN GOMPEL';
		const randomDelay = (base, variance) => base + (Math.random() * variance * 2) - variance;

		let currentIndex = 0;

		// Phase 1: Type "Gert-W"
		const typeNextChar = () => {
			if (currentIndex < typed.length) {
				typedEl.textContent += typed[currentIndex];
				currentIndex++;
				setTimeout(typeNextChar, randomDelay(220, 150));
			} else {
				// Move to phase 2 immediately after last char is typed
				showSuggestionWithTooltip();
			}
		};

		// Phase 2: Show suggestion + tooltip
		const showSuggestionWithTooltip = () => {
			suggestEl.textContent = suggestion;
			tooltipEl.classList.add('visible');
			// Tooltip fades out and suggestion gets accepted
			setTimeout(acceptSuggestion, 1300);
		};

		// Phase 3: Accept suggestion (make it bright)
		const acceptSuggestion = () => {
			tooltipEl.classList.remove('visible');
			suggestEl.classList.add('accepted');
			// Move cursor to end (after suggestion)
			const homeNameEl = document.querySelector('.home-name');
			if (homeNameEl) {
				homeNameEl.appendChild(cursorEl);
			}
			// Pause with full name visible
			setTimeout(startBackspace, 1500);
		};

		// Phase 4: Backspace " VAN GOMPEL"
		const startBackspace = () => {
			let deleteIndex = deleteText.length - 1;

			const backspaceChar = () => {
				if (deleteIndex >= 0) {
					const currentText = typedEl.textContent + suggestEl.textContent;
					const newText = currentText.slice(0, -1);
					// Update the appropriate element
					if (suggestEl.textContent.length > 0) {
						suggestEl.textContent = suggestEl.textContent.slice(0, -1);
					} else {
						typedEl.textContent = typedEl.textContent.slice(0, -1);
					}
					deleteIndex--;
					setTimeout(backspaceChar, randomDelay(70, 40));
				} else {
					// Backspace complete, hide cursor and fade in tagline
					cursorEl.style.display = 'none';
					setTimeout(() => taglineEl.classList.add('fade-in'), 600);
				}
			};

			backspaceChar();
		};

		// Start the effect
		typeNextChar();
	}

	// Run on page load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initTypewriter);
	} else {
		initTypewriter();
	}

</script>
