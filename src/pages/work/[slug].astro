---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('work');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

type Props = CollectionEntry<'work'>;

const project = Astro.props;
const { title, description, stack, githubUrl } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={title} description={description}>
	<main class="work-post">
		<article>
			<header class="post-header">
				<h1 class="post-title">{title}</h1>
				<div class="post-meta">
					<ul class="stack-tags" aria-label="Stack">
						{stack.map((tag) => <li class="stack-tag">{tag}</li>)}
					</ul>
					{
						githubUrl && (
							<a
								href={githubUrl}
								class="github-link"
								target="_blank"
								rel="noopener noreferrer"
							>
								<svg
									width="15"
									height="15"
									viewBox="0 0 16 16"
									fill="currentColor"
									aria-hidden="true"
								>
									<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
								</svg>
								GitHub ↗
							</a>
						)
					}
				</div>
				<p class="post-desc">{description}</p>
				<hr class="header-rule" />
			</header>
			<div class="prose">
				<Content />
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	.work-post {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: calc(var(--nav-h) + 3.5em) 1em 5em;
	}

	/* ─── Header ─── */
	.post-header {
		margin-bottom: 3rem;
	}

	.post-title {
		font-family: var(--font-display);
		font-size: clamp(2rem, 5vw, 3.5rem);
		font-weight: 700;
		color: rgb(var(--black));
		margin: 0 0 1.25rem;
		line-height: 1.05;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		margin-bottom: 1.25rem;
	}

	/* ─── Stack tags ─── */
	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.stack-tag {
		font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
		font-size: 0.68rem;
		font-weight: 400;
		letter-spacing: 0.04em;
		color: rgb(var(--gray));
		background: rgb(var(--gray-light));
		border: 1px solid rgba(255, 255, 255, 0.06);
		padding: 0.2rem 0.55rem;
		border-radius: 2px;
	}

	/* ─── GitHub link ─── */
	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.75rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		text-decoration: none;
		margin-left: auto;
		transition: color 0.18s ease;
	}

	.github-link:hover {
		color: var(--accent);
	}

	/* ─── Description ─── */
	.post-desc {
		font-size: 1rem;
		font-weight: 300;
		color: rgb(var(--gray));
		line-height: 1.6;
		margin: 0;
	}

	.header-rule {
		margin-top: 2rem;
		border: none;
		border-top: 1px solid rgb(var(--gray-light));
	}

	/* ─── Prose ─── */
	.prose {
		font-size: 1rem;
	}

	/* ─── code font in prose ─── */
	:global(.prose code) {
		font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace;
		font-size: 0.85em;
	}

	/* ─── fenced code block ─── */
	:global(.prose pre code) {
		font-size: 0.82rem;
		line-height: 1.65;
	}

	@media (max-width: 480px) {
		.github-link {
			margin-left: 0;
		}
	}
</style>
